# Backend Environment Variables Template
# Copy this file to .env for development

# FastAPI Configuration
DEBUG=True
ENVIRONMENT=development
HOST=localhost
PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./database.db
# For PostgreSQL in production:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/paper2code

# File Storage Configuration
UPLOAD_DIR=../storage/uploads
OUTPUT_DIR=../storage/outputs
TEMP_DIR=../storage/temp
MAX_FILE_SIZE_MB=50

# Paper2Code Integration
PAPER_CODER_CODES_DIR=../codes
PAPER_CODER_SCRIPTS_DIR=../scripts
PAPER_CODER_OUTPUT_BASE_DIR=../outputs

# API Keys (required for Paper2Code)
OPENAI_API_KEY=your_openai_api_key_here

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256

# Logging
LOG_LEVEL=INFO

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30